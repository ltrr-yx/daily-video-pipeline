.DS_Store
__pycache__/
*.py[cod]
*.egg-info/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/

.venv/
venv/

.env
.env.*
!.env.example

# User-owned runtime configuration. Keep real source lists, tokens, BGM paths,
# watchlists, and publishing preferences out of git.
configs/*.local.yml
configs/*.local.yaml
configs/*.private.yml
configs/*.private.yaml
.privacy-blocklist.local

# Runtime artifacts.
outputs/
reports/
data/
logs/
tmp/

# User-provided media should be licensed and local by default.
assets/bgm/*
!assets/bgm/.gitkeep
assets/fonts/*
!assets/fonts/.gitkeep

# Rendered media is generated output, not source.
*.mp4
*.mov
*.m4a
*.mp3
*.wav
*.aiff
